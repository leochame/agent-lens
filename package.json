{
  "name": "agent-lens",
  "version": "1.0.0",
  "description": "Transparent local proxy for LLM request interception and logging",
  "main": "dist/index.js",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/*.test.js dist/*/*.test.js dist/*/*/*.test.js dist/*/*/*/*.test.js",
    "start": "node dist/index.js",
    "dev": "npm run build && node --enable-source-maps dist/index.js"
  },
  "keywords": [
    "proxy",
    "sse",
    "llm",
    "observability"
  ],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.3"
  }
}
