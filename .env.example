# Optional: override config path
# AGENTLENS_CONFIG=./config/default.yaml

# Optional: injected credential for provider authMode.type=inject
# RELAY_B_KEY=your_key_here

# Anthropic relay style upstream (works with provider "anthropic_relay")
# ANTHROPIC_BASE_URL=https://your-relay.example.com
# ANTHROPIC_AUTH_TOKEN=your_token_here
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# API_TIMEOUT_MS=300000
